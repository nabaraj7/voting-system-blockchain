# Copy to .env and fill in values:
#   cp .env.example .env

# RPC endpoint to deploy against (required for remote deploys)
RPC_URL=http://127.0.0.1:8545

# Deployer private key (never commit this)
PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Existing PDSCWorkshop2026 address (required for token/badge-only deploys)
# WORKSHOP_ADDRESS=0x...

# ERC-20 claim reward amount in wei (default: 100 ether)
# CLAIM_AMOUNT=100000000000000000000

# Optional named endpoints used by foundry.toml [rpc_endpoints]
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

